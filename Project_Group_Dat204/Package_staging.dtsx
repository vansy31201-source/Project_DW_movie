          SQLTask:SqlStatementSource="-- ==========================================&#xA;-- BƯỚC 1: XÓA CÁC BẢNG CẦU / LIÊN KẾT (Bảng con - Chứa khóa ngoại)&#xA;-- Xóa nhóm này trước để gỡ bỏ sự phụ thuộc vào các bảng chính&#xA;-- ==========================================&#xA;DELETE FROM dbo.movie_cast;&#xA;DELETE FROM dbo.movie_crew;&#xA;DELETE FROM dbo.movie_genres;&#xA;DELETE FROM dbo.movie_keywords;&#xA;DELETE FROM dbo.movie_languages;&#xA;DELETE FROM dbo.movie_company; &#xA;-- ==========================================&#xA;-- BƯỚC 2: XÓA CÁC BẢNG DANH MỤC / THÔNG TIN CHÍNH (Bảng cha)&#xA;-- Xóa nhóm này sau khi các bảng con đã trống&#xA;-- ==========================================&#xA;DELETE FROM dbo.movie;&#xA;DELETE FROM dbo.person;&#xA;DELETE FROM dbo.production_company;&#xA;DELETE FROM dbo.production_country;&#xA;DELETE FROM dbo.genre;&#xA;DELETE FROM dbo.keyword;&#xA;DELETE FROM dbo.country;&#xA;DELETE FROM dbo.language;&#xA;DELETE FROM dbo.department;&#xA;DELETE FROM dbo.gender;&#xA;DELETE FROM dbo.language_role;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
