          SQLTask:SqlStatementSource="EXEC sp_MSforeachtable 'ALTER TABLE ? NOCHECK CONSTRAINT ALL';&#xA;&#xA;EXEC sp_MSforeachtable 'ALTER TABLE ? WITH CHECK CHECK CONSTRAINT ALL';&#xA;&#xA;-- 1. XÓA DỮ LIỆU CÁC BẢNG CON (Bảng Bridge và Fact)&#xA;DELETE FROM dbo.Bridge_movie_cast;&#xA;DELETE FROM dbo.Bridge_movie_crew;&#xA;DELETE FROM dbo.Bridge_movie_genre;&#xA;DELETE FROM dbo.Bridge_movie_keyword;&#xA;DELETE FROM dbo.Fact_movie;&#xA;&#xA;-- 2. XÓA DỮ LIỆU CÁC BẢNG CHA (Bảng Dimension)&#xA;DELETE FROM dbo.Dim_Company;&#xA;DELETE FROM dbo.Dim_Country;&#xA;DELETE FROM dbo.Dim_Date;&#xA;DELETE FROM dbo.Dim_Department;&#xA;DELETE FROM dbo.Dim_Genre;&#xA;DELETE FROM dbo.Dim_Keyword;&#xA;DELETE FROM dbo.Dim_Language;&#xA;DELETE FROM dbo.Dim_Person;&#xA;DELETE FROM dbo.Dim_Movie;&#xA;&#xA;-- 3. RESET IDENTITY VỀ 0 &#xA;DBCC CHECKIDENT ('dbo.Dim_Movie', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Language', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Company', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Country', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Genre', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Keyword', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Person', RESEED, 0);&#xA;DBCC CHECKIDENT ('dbo.Dim_Department', RESEED, 0);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
