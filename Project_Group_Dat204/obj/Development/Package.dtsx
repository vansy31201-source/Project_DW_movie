          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{59102FDA-A2BD-4B85-B58E-3C777E55AEF2}"
              SQLTask:SqlStatementSource="-- Chạy lại vòng lặp với định dạng chuẩn&#xA;DECLARE @StartDate DATE = '1916-09-04';&#xA;DECLARE @EndDate DATE = '2017-02-03';&#xA;&#xA;WHILE @StartDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO dbo.Dim_Date (Date_key, full_date, [day], [month], [year], [quarter])&#xA;    VALUES (&#xA;        CONVERT(INT, FORMAT(@StartDate, 'yyyyMMdd')), -- Tạo khóa dạng 19160904&#xA;        @StartDate,&#xA;        DAY(@StartDate),&#xA;        MONTH(@StartDate),&#xA;        YEAR(@StartDate),&#xA;        DATEPART(QUARTER, @StartDate)&#xA;    );&#xA;    &#xA;    SET @StartDate = DATEADD(DAY, 1, @StartDate);&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
