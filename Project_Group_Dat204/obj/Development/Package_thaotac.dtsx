                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT language_id, language_code, language_name

FROM [movies].[dbo].[language]

WHERE language_id IS NOT NULL 
 
  AND language_name IS NOT NULL

  AND language_name NOT LIKE '%u00%' -- Loại bỏ các dòng chứa mã lỗi Unicode phổ biến

  AND LEN(language_name) &gt; 2  -- Loại bỏ các tên ngôn ngữ quá ngắn hoặc không hợp lệ</property>
