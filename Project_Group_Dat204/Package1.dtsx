      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{F4B273B8-FCB9-4BAB-895D-3BE086DDA342}"
          SQLTask:SqlStatementSource="EXEC sp_MSforeachtable 'ALTER TABLE ? NOCHECK CONSTRAINT ALL';&#xA;&#xA;EXEC sp_MSforeachtable 'TRUNCATE TABLE ?'&#xA;&#xA;EXEC sp_MSforeachtable 'ALTER TABLE ? WITH CHECK CHECK CONSTRAINT ALL';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Preparation SQL Task 1"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{AB31AE18-3B2B-4289-97C0-E8A5164D1CD1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:FailPackageOnFailure="True"
      DTS:LocaleID="-1"
      DTS:ObjectName="Preparation SQL Task 1"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D2907598-504A-4E4E-B476-9F272A8E25D5}"
          SQLTask:SqlStatementSource="-- 1. Check &amp; Create bảng country&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[country]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[country] (&#xA;        [country_id] int NOT NULL,&#xA;        [country_iso_code] varchar(10),&#xA;        [country_name] varchar(200)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 2. Check &amp; Create bảng department&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[department]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[department] (&#xA;        [department_id] int NOT NULL,&#xA;        [department_name] varchar(200)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 3. Check &amp; Create bảng gender&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[gender]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[gender] (&#xA;        [gender_id] int NOT NULL,&#xA;        [gender] varchar(20)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 4. Check &amp; Create bảng genre&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[genre]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[genre] (&#xA;        [genre_id] int NOT NULL,&#xA;        [genre_name] varchar(100)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 5. Check &amp; Create bảng keyword&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[keyword]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[keyword] (&#xA;        [keyword_id] int NOT NULL,&#xA;        [keyword_name] varchar(200)&#xA;    )&#xA;END&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Preparation SQL Task 2"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{90A4019F-0B88-4AA4-A072-8DC548E2F666}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:FailPackageOnFailure="True"
      DTS:LocaleID="-1"
      DTS:ObjectName="Preparation SQL Task 2"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D2907598-504A-4E4E-B476-9F272A8E25D5}"
          SQLTask:SqlStatementSource="-- 1. Check &amp; Create bảng language&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[language]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[language] (&#xA;        [language_id] int NOT NULL,&#xA;        [language_code] varchar(10),&#xA;        [language_name] varchar(500)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 2. Check &amp; Create bảng language_role&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[language_role]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[language_role] (&#xA;        [role_id] int NOT NULL,&#xA;        [language_role] varchar(20)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 3. Check &amp; Create bảng movie&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie] (&#xA;        [movie_id] int NOT NULL,&#xA;        [title] varchar(1000),&#xA;        [budget] bigint,&#xA;        [homepage] varchar(1000),&#xA;        [overview] varchar(1000),&#xA;        [popularity] decimal(12,6),&#xA;        [release_date] varchar(30),&#xA;        [revenue] bigint,&#xA;        [runtime] int,&#xA;        [movie_status] varchar(50),&#xA;        [tagline] varchar(1000),&#xA;        [vote_average] decimal(4,2),&#xA;        [vote_count] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 4. Check &amp; Create bảng movie_cast&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_cast]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_cast] (&#xA;        [movie_id] int,&#xA;        [person_id] int,&#xA;        [character_name] varchar(400),&#xA;        [gender_id] int,&#xA;        [cast_order] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 5. Check &amp; Create bảng movie_company&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_company]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_company] (&#xA;        [movie_id] int,&#xA;        [company_id] int&#xA;    )&#xA;END&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Preparation SQL Task 3"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{5604B624-EB0D-41DB-960F-14D58240D0B3}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:FailPackageOnFailure="True"
      DTS:LocaleID="-1"
      DTS:ObjectName="Preparation SQL Task 3"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D2907598-504A-4E4E-B476-9F272A8E25D5}"
          SQLTask:SqlStatementSource="-- 1. Check &amp; Create bảng movie_crew&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_crew]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_crew] (&#xA;        [movie_id] int,&#xA;        [person_id] int,&#xA;        [department_id] int,&#xA;        [job] varchar(200)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 2. Check &amp; Create bảng movie_genres&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_genres]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_genres] (&#xA;        [movie_id] int,&#xA;        [genre_id] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 3. Check &amp; Create bảng movie_keywords&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_keywords]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_keywords] (&#xA;        [movie_id] int,&#xA;        [keyword_id] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 4. Check &amp; Create bảng movie_languages&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[movie_languages]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[movie_languages] (&#xA;        [movie_id] int,&#xA;        [language_id] int,&#xA;        [language_role_id] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 5. Check &amp; Create bảng person&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[person]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[person] (&#xA;        [person_id] int NOT NULL,&#xA;        [person_name] varchar(500)&#xA;    )&#xA;END&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Preparation SQL Task 4"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A48EB4D3-0B99-4CCA-84E1-D5F08BF246AE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:FailPackageOnFailure="True"
      DTS:LocaleID="-1"
      DTS:ObjectName="Preparation SQL Task 4"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D2907598-504A-4E4E-B476-9F272A8E25D5}"
          SQLTask:SqlStatementSource="-- 1. Check &amp; Create bảng production_company&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[production_company]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[production_company] (&#xA;        [company_id] int NOT NULL,&#xA;        [company_name] varchar(200)&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 2. Check &amp; Create bảng production_country&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[production_country]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[production_country] (&#xA;        [movie_id] int,&#xA;        [country_id] int&#xA;    )&#xA;END&#xA;GO&#xA;&#xA;-- 3. Check &amp; Create bảng sysdiagrams&#xA;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[sysdiagrams]') AND type in (N'U'))&#xA;BEGIN&#xA;    CREATE TABLE [dbo].[sysdiagrams] (&#xA;        [name] nvarchar(128) NOT NULL,&#xA;        [principal_id] int NOT NULL,&#xA;        [diagram_id] int NOT NULL,&#xA;        [version] int,&#xA;        [definition] varbinary(max)&#xA;    )&#xA;END&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
